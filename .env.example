# ─────────────────────────────────────────────────────────
# VedaAI Assessment Creator — Environment Variables
# Copy this file to `.env` and fill in your values
# All client-side vars MUST be prefixed with VITE_
# ─────────────────────────────────────────────────────────

# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:4000

# WebSocket URL (Socket.io connection)
VITE_WS_URL=ws://localhost:4000

# OpenAI API Key (optional — only if calling LLM from client)
# Get yours at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App Metadata
VITE_APP_NAME=VedaAI Assessment Creator
VITE_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────
# Backend-only variables (for separate backend service)
# ─────────────────────────────────────────────────────────

# Server Port
# PORT=4000

# MongoDB Connection String
# Get free cluster at: https://www.mongodb.com/atlas
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vedaai

# Redis Connection (local or Upstash)
# REDIS_URL=redis://localhost:6379

# JWT Secret (use a strong random string, min 32 chars)
# JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Node Environment
# NODE_ENV=development

# Frontend URL (for CORS)
# FRONTEND_URL=http://localhost:5173
